# ============================================================
# QueueLess AI — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/queuelessdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=queuelessdb
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Supabase (if using Supabase instead of local Postgres)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── AI / OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-...your-openai-key...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── JWT Auth ──────────────────────────────────────────────
JWT_SECRET_KEY=your-256-bit-random-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Backend ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_CORS_ORIGINS=http://localhost:3000,https://queueless-web.vercel.app
ENVIRONMENT=development

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# ── Frontend (Next.js) ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=QueueLess AI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (Optional stub) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@queueless.co.za

# ── File Storage ──────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# ── Security ──────────────────────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1
SECRET_KEY=another-random-secret-for-sessions
